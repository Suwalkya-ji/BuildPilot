# ============================================================
# BuildPilot AI — Client Environment Variables (Vite)
# ============================================================
# Copy this file to .env and fill in your actual values.
# All client-side variables MUST be prefixed with VITE_
# Never commit the real .env file to version control.
# ============================================================

# ── API Base URL ──────────────────────────────────────────────
# Backend Express server API URL
# Development: http://localhost:8000/api/v1
# Production:  https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Socket.IO URL ─────────────────────────────────────────────
# Backend Express server Socket.IO root URL (no /api path)
# Development: http://localhost:8000
# Production:  https://api.yourdomain.com
VITE_SOCKET_URL=http://localhost:8000
