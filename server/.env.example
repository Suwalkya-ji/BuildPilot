# ============================================================
# BuildPilot AI — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/buildpilot?retryWrites=true&w=majority

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# ── Groq AI API ───────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hugging Face (Embeddings) ─────────────────────────────────
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Brevo Email & SMTP ───────────────────────────────────────────
BREVO_API_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SMTP_USER=a1b95c001@smtp-brevo.com
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME="BuildPilot AI"

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Qdrant Vector DB ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── CORS / Client URL ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173
