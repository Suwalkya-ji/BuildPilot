# ============================================================
# BuildPilot AI — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port the Express server listens on
PORT=8000

# Node environment: development | production | test
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
# MongoDB Atlas connection string or local MongoDB URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/buildpilot?retryWrites=true&w=majority

# ── JWT Authentication ────────────────────────────────────────
# Strong random secret key (min 32 chars). Generate with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here
# Token expiry duration (e.g. 7d, 24h, 30d)
JWT_EXPIRE=7d

# ── Groq AI API ───────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hugging Face (Embeddings) ─────────────────────────────────
# Get your API token at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────
# Redis host (Docker: 127.0.0.1 | Cloud: your Redis host URL)
REDIS_HOST=127.0.0.1
# Redis port (default: 6379)
REDIS_PORT=6379

# ── Qdrant Vector DB ──────────────────────────────────────────
# Qdrant URL (Docker local: http://localhost:6333 | Cloud: https://your-cluster.qdrant.io)
QDRANT_URL=http://localhost:6333

# ── CORS / Client URL ─────────────────────────────────────────
# Frontend URL (dev: http://localhost:5173 | prod: https://yourdomain.com)
CLIENT_URL=http://localhost:5173
